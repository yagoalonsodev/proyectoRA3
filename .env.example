## Polymarket
POLYMARKET_BASE_URL=https://gamma-api.polymarket.com
POLYMARKET_KEYWORDS=CSGO,Counter-Strike

## S3 DataLake (RAW)
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
S3_BUCKET=
S3_PREFIX=polymarket

## Neon (Postgres) Data Warehouse
# Formato: postgresql+psycopg://USER:PASSWORD@HOST/DB?sslmode=require
NEON_DATABASE_URL=

## LLM (para LangGraph)
LLM_PROVIDER=ollama
# Si LLM_PROVIDER=ollama:
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-coder:6.7b
#
# Si LLM_PROVIDER=openai:
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
